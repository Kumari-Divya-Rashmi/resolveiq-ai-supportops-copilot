NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173
# Leave MONGODB_URI blank for local in-memory demo mode, or set Atlas for persistence.
MONGODB_URI=
USE_MEMORY_DB=false
AUTO_SEED=false
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AI_CONFIDENCE_THRESHOLD=0.74
UPLOAD_DIR=src/uploads
DEMO_USER_PASSWORD=replace-with-your-local-demo-password